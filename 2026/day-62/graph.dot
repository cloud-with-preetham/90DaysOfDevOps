digraph G {
  rankdir = "RL";
  node [shape = rect, fontname = "sans-serif"];
  "aws_instance.main" [label="aws_instance.main"];
  "aws_internet_gateway.igw" [label="aws_internet_gateway.igw"];
  "aws_route_table.rt" [label="aws_route_table.rt"];
  "aws_route_table_association.rta" [label="aws_route_table_association.rta"];
  "aws_s3_bucket.logs" [label="aws_s3_bucket.logs"];
  "aws_security_group.sg" [label="aws_security_group.sg"];
  "aws_subnet.public" [label="aws_subnet.public"];
  "aws_vpc.main" [label="aws_vpc.main"];
  "aws_instance.main" -> "aws_security_group.sg";
  "aws_instance.main" -> "aws_subnet.public";
  "aws_internet_gateway.igw" -> "aws_vpc.main";
  "aws_route_table.rt" -> "aws_internet_gateway.igw";
  "aws_route_table_association.rta" -> "aws_route_table.rt";
  "aws_route_table_association.rta" -> "aws_subnet.public";
  "aws_s3_bucket.logs" -> "aws_instance.main";
  "aws_security_group.sg" -> "aws_vpc.main";
  "aws_subnet.public" -> "aws_vpc.main";
}
